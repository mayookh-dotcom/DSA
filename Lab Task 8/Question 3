#include <stdio.h>
#include <stdlib.h>

struct node{
    int data;
    struct node *next;
};

struct node* create(int n){
    struct node *head=NULL,*temp,*prev=NULL;

    for(int i=0;i<n;i++){
        temp=(struct node*)malloc(sizeof(struct node));
        scanf("%d",&temp->data);

        if(head==NULL)
            head=temp;
        else
            prev->next=temp;

        prev=temp;
    }

    prev->next=head;
    return head;
}

struct node* deleteLast(struct node *head){
    struct node *ptr=head;

    while(ptr->next->next!=head)
        ptr=ptr->next;

    struct node *temp=ptr->next;
    ptr->next=head;
    free(temp);

    return head;
}

void display(struct node *head){
    struct node *ptr=head;

    do{
        printf("%d ",ptr->data);
        ptr=ptr->next;
    }while(ptr!=head);
}

int main(){
    int n;
    scanf("%d",&n);

    struct node *head=create(n);

    head=deleteLast(head);

    display(head);
}
