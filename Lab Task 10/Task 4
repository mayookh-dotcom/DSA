#include <stdio.h>

int main() {
    int n;
    printf("Enter the size of the array: ");
    scanf("%d", &n);

    int arr[10];

    printf("Enter %d sorted elements: ", n);
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int x;
    printf("Enter the target value: ");
    scanf("%d", &x);

    int low = 0, high = n - 1;
    int found = -1;

    while(low <= high) {
        int mid = (low + high) / 2;

        if(arr[mid] == x) {
            found = mid;
            break;
        }
        else if(arr[mid] < x) {
            low = mid + 1;
        }
        else {
            high = mid - 1;
        }
    }

    if(found != -1) {1
        printf("The target value %d is present at index %d", x, found);
    } else {
        printf("The target value %d is not present in the array", x);
    }

    return 0;
}
