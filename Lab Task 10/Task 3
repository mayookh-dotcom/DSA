#include <stdio.h>

int main() {
    int n;
    printf("Enter the size of the array: ");
    scanf("%d", &n);
    int arr[10];
    printf("Enter %d sorted elements: ", n);
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int key;
    printf("Enter the key value: ");
    scanf("%d", &key);
    int count = 0;
    for(int i = 0; i < n; i++) {
        if(arr[i] <= key) {
            count++;
        }
    }

    printf("Count of elements less than or equal to %d: %d", key, count);

    return 0;
}
